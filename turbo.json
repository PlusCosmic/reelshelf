{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "build:api": {
      "cache": false
    },
    "generate:openapi": {
      "cache": false
    },
    "generate:api-client": {
      "dependsOn": ["generate:openapi"],
      "cache": false
    },
    "lint": {},
    "//#format:check": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
