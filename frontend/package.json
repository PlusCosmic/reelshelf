{
  "name": "reelshelf-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --clearScreen false",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run --passWithNoTests --exclude \"**/node_modules/**\" --exclude \"**/node_modules.stale-nobody/**\" --exclude \"**/.git/**\"",
    "preview": "vite preview",
    "generate:api-client": "openapi-generator-cli generate -i src/api-client/Reelshelf.json -g typescript-fetch -o src/api-client --global-property apiDocs=false,modelDocs=false --additional-properties=supportsES6=true,typescriptThreePlus=true,withSeparateModelsAndApi=true,apiPackage=apis,modelPackage=models"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.159.5",
    "@tanstack/react-router-devtools": "^1.159.5",
    "@tanstack/router-plugin": "^1.159.5",
    "crypto-js": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.25.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^24.10.12",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@eslint/js": "^9.39.2",
    "@vitejs/plugin-react": "^5.1.3",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
