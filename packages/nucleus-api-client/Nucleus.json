        "required": [
          "total_processed",
          "success_count",
          "failure_count"
        ],
        "type": "object",
        "properties": {
          "total_processed": {
            "type": "integer",
            "format": "int32"
          },
          "success_count": {
            "type": "integer",
            "format": "int32"
          },
          "failure_count": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "BunnyVideo": {
        "required": [
          "video_library_id",
          "guid",
          "title",
          "date_uploaded",
          "length",
          "status",
          "framerate",
          "thumbnail_count",
