        "required": [
          "standard_map",
          "standard_map_next",
          "ranked_map",
          "ranked_map_next",
          "correct_as_of"
        ],
        "type": "object",
        "properties": {
          "standard_map": {
            "$ref": "#/components/schemas/MapInfo"
          },
          "standard_map_next": {
            "$ref": "#/components/schemas/MapInfo"
          },
          "ranked_map": {
            "$ref": "#/components/schemas/MapInfo"
          },
          "ranked_map_next": {
            "$ref": "#/components/schemas/MapInfo"
          },
          "correct_as_of": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DiscordUser": {
        "required": [
          "id",
          "username",
          "global_name",
          "avatar"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "username": {
            "type": "string"
          },
          "global_name": {
            "type": "string",
            "nullable": true
