        "type": "object",
        "properties": {
          "signature": {
            "type": "string"
          },
          "expiration": {
            "type": "integer",
            "format": "int64"
          },
          "library_id": {
            "type": "string"
          },
          "video_id": {
            "type": "string",
            "format": "uuid"
          },
          "collection_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
