            "format": "int32"
          },
          "framerate": {
            "type": "number",
            "format": "double"
          },
          "thumbnail_count": {
            "type": "integer",
            "format": "int32"
          },
          "encode_progress": {
            "type": "integer",
            "format": "int32"
          },
          "storage_size": {
            "type": "integer",
            "format": "int64"
          },
          "collection_id": {
            "type": "string",
            "format": "uuid"
          },
          "thumbnail_file_name": {
            "type": "string"
          },
          "thumbnail_blurhash": {
            "type": "string"
