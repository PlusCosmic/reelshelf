        "required": [
          "clip_id",
          "owner_id",
          "video_id",
          "category_enum",
          "created_at",
          "video",
          "tags",
          "is_viewed",
          "detected_legend",
          "detected_legend_card"
        ],
        "type": "object",
        "properties": {
          "clip_id": {
            "type": "string",
            "format": "uuid"
          },
          "owner_id": {
            "type": "string",
            "format": "uuid"
          },
          "video_id": {
            "type": "string",
            "format": "uuid"
          },
          "category_enum": {
            "$ref": "#/components/schemas/ClipCategoryEnum"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "video": {
            "$ref": "#/components/schemas/BunnyVideo"
