  "components": {
    "schemas": {
      "BackupFileInfo": {
        "required": [
          "path",
          "size",
          "last_modified"
        ],
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "format": "int64"
          },
          "last_modified": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BackupListResult": {
        "required": [
          "is_configured",
          "local_files",
          "remote_files",
          "pending_sync_count"
        ],
        "type": "object",
        "properties": {
          "is_configured": {
            "type": "boolean"
          },
          "local_files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BackupFileInfo"
            }
          },
          "remote_files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BackupFileInfo"
            }
          },
          "pending_sync_count": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "BackupSyncResult": {
        "required": [
          "success",
          "message",
          "files_uploaded",
          "files_skipped",
          "bytes_uploaded"
        ],
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "files_uploaded": {
            "type": "integer",
            "format": "int32"
          },
          "files_skipped": {
            "type": "integer",
            "format": "int32"
          },
          "bytes_uploaded": {
            "type": "integer",
            "format": "int64"
          },
          "files_deleted": {
            "type": "integer",
            "format": "int32",
            "default": 0
          },
